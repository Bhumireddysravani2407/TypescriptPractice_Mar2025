{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "rootDir": "./src",
    "outDir": "./dist",

       "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": [],
    "noEmitOnError": true,
    "noEmit": true
    
  },
  "include":[
    "src/**/*.ts"
  ],
  "exclude":[
    "dist"
  ]
}
